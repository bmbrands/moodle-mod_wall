{{!
    @template mod_wall/comment_thread

    Comment thread - re-rendered via AJAX after state changes.

    Context variables required:
    * wallid - Wall instance ID
    * comments - Array of comment objects (may be empty initially)
    * hascomments - Whether there are comments
    * cancomment - Whether the user can add comments
    * enablevoting - Whether voting is enabled

    Example context (json):
    {
        "wallid": 1,
        "comments": [],
        "hascomments": false,
        "cancomment": true,
        "enablevoting": true
    }
}}
{{#cancomment}}
{{> mod_wall/comment_form}}
{{/cancomment}}

<div data-region="comment-list" data-wallid="{{wallid}}">
    {{#hascomments}}
    {{#comments}}
    {{> mod_wall/comment_item}}
    {{/comments}}
    {{/hascomments}}
    {{^hascomments}}
    <p class="text-muted small mt-3">{{#str}}nocomments, mod_wall{{/str}}</p>
    {{/hascomments}}
</div>
