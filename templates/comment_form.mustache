{{!
    @template mod_wall/comment_form

    Comment form for adding a top-level comment. Displayed at the top of the thread.

    Context variables required:
    * wallid - Wall instance ID

    Example context (json):
    {
        "wallid": 1
    }
}}
<div class="mod-wall-comment-form mb-3" data-region="comment-form" data-wallid="{{wallid}}">
    <div class="input-group">
        <textarea class="form-control" rows="2"
                  data-region="comment-input" data-wallid="{{wallid}}"
                  placeholder="{{#str}}addcomment, mod_wall{{/str}}"></textarea>
        <div class="input-group-append">
            <button class="btn btn-primary" data-action="submit-comment"
                    data-wallid="{{wallid}}" data-parentid="0">
                <i class="fa fa-paper-plane"></i>
            </button>
        </div>
    </div>
</div>
