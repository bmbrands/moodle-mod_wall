{{!
    @template mod_wall/course_page

    Compact course page bar for a wall instance.
    Shows a collapsed summary row with an independent wall score and comment count.
    The wall score is separate from comment votes - it's a vote on the element itself.
    Clicking the comments area expands the full comment thread (loaded via AJAX).

    Context variables required:
    * cmid - Course module ID
    * wallid - Wall instance ID
    * enablevoting - Whether voting is enabled
    * wallscore - Independent net vote score for the wall instance
    * walluservote - Current user's vote on the wall (1, -1, or 0)
    * walluserupvoted - Whether the user upvoted the wall
    * walluserdownvoted - Whether the user downvoted the wall
    * commentcount - Total number of comments
    * hasmedia - Whether the wall has a media file
    * mediaurl - URL to the media file
    * mediaimage - Whether the media is an image
    * mediavideo - Whether the media is a video

    Example context (json):
    {
        "cmid": 123,
        "wallid": 1,
        "enablevoting": true,
        "wallscore": 5,
        "walluservote": 1,
        "walluserupvoted": true,
        "walluserdownvoted": false,
        "commentcount": 12,
        "hasmedia": true,
        "mediaurl": "/pluginfile.php/123/mod_wall/media/0/photo.jpg",
        "mediaimage": true,
        "mediavideo": false
    }
}}
<div class="mod-wall-coursepage" data-region="wall-view" data-cmid="{{cmid}}" data-wallid="{{wallid}}">
    {{#hasmedia}}
    <div class="mod-wall-media mb-2">
        {{#mediaimage}}
        <img src="{{mediaurl}}" alt="" class="img-fluid rounded">
        {{/mediaimage}}
        {{#mediavideo}}
        <video src="{{mediaurl}}" controls class="w-100 rounded">
        </video>
        {{/mediavideo}}
    </div>
    {{/hasmedia}}
    <div class="d-flex align-items-center py-1">
        {{#enablevoting}}
        <div class="d-flex align-items-center me-3" data-region="wall-vote-bar">
            <button class="btn btn-sm btn-link p-0 {{#walluserupvoted}}text-primary{{/walluserupvoted}}{{^walluserupvoted}}text-muted{{/walluserupvoted}}"
                    data-action="vote-wall" data-vote="1"
                    title="{{#str}}upvote, mod_wall{{/str}}">
                <i class="fa fa-arrow-up"></i>
            </button>
            <span class="small fw-bold mx-1 {{#walluserupvoted}}text-primary{{/walluserupvoted}}{{#walluserdownvoted}}text-danger{{/walluserdownvoted}}"
                  data-region="wall-score">{{wallscore}}</span>
            <button class="btn btn-sm btn-link p-0 {{#walluserdownvoted}}text-danger{{/walluserdownvoted}}{{^walluserdownvoted}}text-muted{{/walluserdownvoted}}"
                    data-action="vote-wall" data-vote="-1"
                    title="{{#str}}downvote, mod_wall{{/str}}">
                <i class="fa fa-arrow-down"></i>
            </button>
        </div>
        {{/enablevoting}}
        <a href="#" data-action="toggle-wall" class="d-flex align-items-center text-decoration-none text-body">
            <i class="fa fa-comment-o me-1"></i>
            <span class="small"><span data-region="wall-commentcount">{{commentcount}}</span> {{#str}}comments, mod_wall{{/str}}</span>
        </a>
    </div>
    <div data-region="wall-expanded" style="display: none;">
        <div data-region="comment-thread" data-wallid="{{wallid}}">
        </div>
    </div>
</div>
