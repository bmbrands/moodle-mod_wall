{{!
    @template mod_wall/comment_reply_form

    Inline reply form for a comment.

    When used as a partial inside comment_item, the parent context provides:
    * wallid - Wall instance ID
    * id - Comment ID (used as parentid for the reply)

    Example context (json):
    {
        "wallid": 1,
        "id": 42
    }
}}
<div class="mt-2 me-4" data-region="comment-form">
    <div class="input-group input-group-sm">
        <textarea class="form-control form-control-sm" rows="1"
                  data-region="comment-input"
                  placeholder="{{#str}}reply, mod_wall{{/str}}"></textarea>
        <div class="input-group-append">
            <button class="btn btn-sm btn-primary" data-action="submit-comment"
                    data-wallid="{{wallid}}" data-parentid="{{id}}">
                <i class="fa fa-paper-plane"></i>
            </button>
        </div>
    </div>
</div>
